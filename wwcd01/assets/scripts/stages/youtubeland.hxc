    // Load and play video on demand for HTML5 compatibility
    function loadAndPlayVideo(isGoodEnding:Bool) {
        game = PlayState.instance;

        // For HTML5, strip the library prefix from the path
        var videoPath:String = isGoodEnding ? Paths.videos("OLB-Good") : Paths.videos("OLB-Bad");
        videoPath = Paths.stripLibrary(videoPath);

        try {
            if (isGoodEnding) {
                lyricsGood = new FlxVideo(videoPath);
                lyricsGood.cameras = [game.camCutscene];
                lyricsGood.zIndex = 2001;
                //lyricsGood.screenCenter();
                PlayState.instance.add(lyricsGood);
                videoLoaded = true;
            } else {
                lyricsLol = new FlxVideo(videoPath);
                lyricsLol.cameras = [game.camCutscene];
                lyricsLol.zIndex = 2000;
                //lyricsLol.screenCenter();
                PlayState.instance.add(lyricsLol);
                videoLoaded = true;
            }
        } catch (e:Dynamic) {
            trace("Video loading failed: " + e);
            videoLoaded = false;
        }
    }

    function setupLikeButton() {
        var game = PlayState.instance;
        likeButton = new FlxButton(FlxG.width / 3, -10, "", function() {
            likeCount++;
            game.songScore += 100;
            game.health += 0.02;
            if (likeCount >= 25) unlockedGoodEnding = true;
            FlxTween.num(0.65, 0.7, 0.15, {ease: FlxEase.cubeOut}, function(t) {
                likeButton.scale.set(t, t);
            });
        });
        likeButton.loadGraphic(Paths.image('ui/helpMeBruh'));
        likeButton.scale.set(0.7, 0.7);
        likeButton.cameras = [game.camCutscene];
        likeButton.scrollFactor.set(0, 0);
        likeButton.zIndex = 1200;
        PlayState.instance.add(likeButton);
        FlxTween.tween(likeButton, {y: 90}, 1, {ease: FlxEase.cubeOut});
    }

    override function onCountdownStart(event):Void {
        super.onCountdownStart(event);
        event.cancel();
        PlayState.instance.isInCountdown = true;
        PlayState.instance.mayPauseGame = true;
        PlayState.instance.startSong();
    }

    override function onSongEvent(event:ScriptEvent):Void {
        super.onSongEvent(event);
        var ev = event.eventData;
        if (ev == null) return;

        if (ev.eventKind == "lyricschidas") {
            var text:String = ev.value.text ?? "";
            if (text == "" || text == " ") {
                if (lyricsTextChidas != null) lyricsTextChidas.visible = false;
                return;
            }
            if (lyricsTextChidas == null || !lyricsTextChidas.exists) {
                lyricsTextChidas = new FlxText(0, 630, FlxG.width, "");
                lyricsTextChidas.setFormat(Paths.font("MDP.ttf"), 50, 0xFFF7F1DF, "center", FlxTextBorderStyle.OUTLINE, FlxColor.BLACK);
                lyricsTextChidas.borderSize = 1.7;
                lyricsTextChidas.antialiasing = true;
                lyricsTextChidas.scale.set(0.85, 0.85);
                lyricsTextChidas.cameras = [PlayState.instance.camCutscene];
                lyricsTextChidas.zIndex = 10000;
                PlayState.instance.add(lyricsTextChidas);
            }
            lyricsTextChidas.text = text;
            lyricsTextChidas.visible = true;
            lyricsTextChidas.screenCenter(0x01);
        }
    }

    override function onUpdate(elapsed:Float) {
        super.onUpdate(elapsed);
        game = PlayState.instance;
        if (game.iconP1 != null) { game.iconP1.visible = false; game.iconP1.zIndex = 0; }
        if (game.iconP2 != null) { game.iconP2.visible = false; game.iconP2.zIndex = 0; }

        var targetHP:Float = FlxMath.bound(game.health / 2, 0, 1);
        healthPercentButActually = FlxMath.lerp(healthPercentButActually, targetHP, 0.1);

        if (batteryGradient != null) {
            _clipRect.width = BATTERY_WIDTH * healthPercentButActually;
            _clipRect.height = BATTERY_HEIGHT;
            batteryGradient.clipRect = _clipRect;
        }

        var targetAnim:String = 'danger';
        if (healthPercentButActually > 0.75) targetAnim = 'full';
        else if (healthPercentButActually > 0.50) targetAnim = 'good';
        else if (healthPercentButActually > 0.25) targetAnim = 'warning';

        if (healthIcon.animation.curAnim == null || healthIcon.animation.curAnim.name != targetAnim) {
            healthIcon.animation.play(targetAnim);
        }

        scoreText.text = "Score: " + formatScore(game.songScore);
        missText.text = "Misses: " + Highscore.tallies.missed;

        updateHUDVisibility();

        var mdpSpr = getNamedProp('MDP');
        if (mdpSpr != null) {
            var sky = getNamedProp('Sky');
            mdpSpr.visible = (sky != null && !sky.visible);
        }
    }

    function updateHUDVisibility() {
        var targetAnim = (healthPercentButActually > 0.75) ? 'full' : (healthPercentButActually > 0.50) ? 'good' : (healthPercentButActually > 0.25) ? 'warning' : 'danger';
        if (healthIcon.animation.curAnim == null || healthIcon.animation.curAnim.name != targetAnim) healthIcon.animation.play(targetAnim);

        watermark.visible = batteryGradient.visible = batteryBG.visible = batteryBorder.visible = MDP;
        rightBar.visible = leftBar.visible = shortGradientTop.visible = shortGradientBottom.visible = MDP;
        healthIcon.visible = scoreText.visible = missText.visible = !MDP;

        if (!MDP) {
            dontZoomYet = false;
            PlayState.instance.camGame.filters = [];
        }
    }

    override function onBeatHit(event:SongTimeScriptEvent) {
        super.onBeatHit(event);
        game = PlayState.instance;
        switch(event.beat) {
            case 1:
                FlxTween.tween(blackScreen, {alpha: 0}, 2);
            case 2:
                FlxTween.tween(game.camHUD, {alpha: 1}, 2);
            case 65:
                FlxTween.tween(game.camHUD, {alpha: 0}, 1, {ease: FlxEase.cubeIn});
                tweenPlayerAlpha(0, 1);
            case 66:
                FlxTween.tween(blackScreen, {alpha: 1}, 0.67, {ease: FlxEase.quintIn});
                pibbuh.visible = true;
                pibbuh.animation.play("scary");
            case 70:
                realStage(true);
                pibbuh.visible = false;
                MDP = false;
            case 72, 73, 74, 75, 77, 78, 79:
                blackScreen.alpha = 0;
            case 76:
                FlxTween.tween(game.camHUD, {alpha: 1}, 1, {ease: FlxEase.cubeIn});
                tweenPlayerAlpha(1, 1);
            case 212:
                realStage(false);
                getBoyfriend().alpha = getDad().alpha = 0;
                yellowBG = new FlxSprite(-850, -400).makeGraphic(4000, 3000, 0xFFfff000);
                yellowBG.zIndex = 90; add(yellowBG);
                blueBG = new FlxSprite(-850, -400).makeGraphic(4000, 3000, 0xFF3e99ff);
                blueBG.alpha = 0; blueBG.zIndex = 91; add(blueBG);
                nugRun.visible = maxRun.visible = true;
                maxRun.animation.play("run"); nugRun.animation.play("run");
                FlxTween.tween(maxRun, {x: 25}, 2, {ease: FlxEase.quartOut});
                FlxTween.tween(nugRun, {x: 985}, 1.8, {ease: FlxEase.quartOut});
            case 274:
                maxRun.animation.play("huh");
                nugRun.offset.set(30, -80);
                nugRun.animation.play("slide");
                FlxTween.tween(maxRun, {x: -250}, 1.5, {ease: FlxEase.quartOut});
                FlxTween.tween(nugRun, {x: 800}, 1.2, {ease: FlxEase.quartOut});
                FlxTween.tween(game.camHUD, {alpha: 0}, 1, {ease: FlxEase.cubeInOut});
            case 275:
                nugRun.animation.play("what");
                nugRun.offset.set(0, -80);
            case 276:
                maxRun.animation.play("crank");
                maxRun.offset.set(100, -50);
                nugRun.animation.play("help");
                FlxTween.tween(blueBG, {alpha: 1}, 10, {ease: FlxEase.sineInOut});
                setupLikeButton();
                FlxG.mouse.visible = true;
                tweenPlayerAlpha(0, 1);
            case 306:
                if (likeButton != null) FlxTween.tween(likeButton, {y: -150}, 0.5, {ease: FlxEase.cubeIn});
                FlxTween.tween(blackScreen, {alpha: 1}, 0.2, {ease: FlxEase.cubeIn});
            case 310:
                if (unlockedGoodEnding) {
                    FlxG.sound.play(Paths.sound("goodSFX"));
                    FlxG.save.data.OLB_GoodEnd = true;
                    FlxG.save.data.lastEnding = "Good";
                } else {
                    FlxG.save.data.OLB_BadEnd = true;
                    FlxG.save.data.lastEnding = "Bad";
                }
                FlxG.save.flush();
                yellowBG.visible = blueBG.visible = maxRun.visible = nugRun.visible = false;
            case 312:
                // Load and play video on-demand for HTML5 compatibility
                loadAndPlayVideo(unlockedGoodEnding);
                // game.playerStrumline.zIndex = 2500; game.refresh();
                FlxG.mouse.visible = false;
                changeStrumsAlpha(0);
            case 328:
                tweenPlayerAlpha(0.67, 1);
            case 368:
                tweenPlayerAlpha(0, 1);
            case 386:
                MDP = false; realStage(true);
                // Hide and cleanup videos
                if (lyricsGood != null) { lyricsGood.visible = false; lyricsGood.destroy(); lyricsGood = null; }
                if (lyricsLol != null) { lyricsLol.visible = false; lyricsLol.destroy(); lyricsLol = null; }
                FlxTween.tween(blackScreen, {alpha: 0}, 0.3, {ease: FlxEase.cubeOut});
                getBoyfriend().alpha = getDad().alpha = 1;
                if (unlockedGoodEnding) {
                    triggerEvent('Change Character', 'bf', 'nugget-alt');
                }
                tweenPlayerAlpha(1, 1);
                FlxTween.tween(game.camHUD, {alpha: 1}, 1, {ease: FlxEase.cubeInOut});
                game.playerStrumline.zIndex = 1000; game.refresh();
                redTint = new FlxSprite(0, 0).makeGraphic(Std.int(FlxG.width), Std.int(FlxG.height), 0xffff1616);
                redTint.cameras = [game.camHUD];
                redTint.alpha = 0.3; redTint.blend = 9; redTint.zIndex = 1150;
                game.add(redTint);
            case 460:
                if (!unlockedGoodEnding) {
                    game.camHUD.visible = false;
                    broDied.visible = true;
                }
            case 462:
                tweenPlayerAlpha(0, 0.5);
                if (unlockedGoodEnding) blackScreen.alpha = 1; else {
                    yellowScreen.visible = true;
                    songLogo.loadGraphic(Paths.image('logo/OLBWHITE'));
                }
                songLogo.visible = true;
                game.camHUD.visible = redTint.visible = broDied.visible = false;
                FlxG.save.flush();
            case 464:
                FlxTween.tween(blackScreen2, {alpha: 1}, 1.5);
        }
    }

    function realStage(show:Bool) {
        for (name in realStageGroup) {
            var spr = getNamedProp(name);
            if (spr != null) { spr.visible = show; }
        }
        var mdpSpr = getNamedProp('MDP');
        if (mdpSpr != null) mdpSpr.visible = !show;
    }

    function formatScore(score:Int):String {
        var scoreStr = Std.string(score);
        var result = "";
        var len = scoreStr.length;
        for (i in 0...len) {
            result += scoreStr.charAt(i);
            var rev = len - 1 - i;
            if (rev > 0 && rev % 3 == 0) result += ",";
        }
        return result;
    }

    override function onNoteHit(event) {
        super.onNoteHit(event);

        var game = PlayState.instance;
        var beatDur:Float = 60 / Conductor.instance.bpm;
        var curBeat:Float = (Conductor.instance.songPosition / 1000) / beatDur;

        if (!event.note.noteData.getMustHitNote()) {
            if (curBeat > 70 && curBeat < 386) {
                if (game.health > 0.4) {
                    game.health -= 0.019;
                }
            }

            if (curBeat > 386) {
                if (!unlockedGoodEnding) {
                    if (game.health > 0.4)
                        game.health -= 0.023;
                }
            }
        }
    }

    override public function onPause(event) {
        super.onPause(event);
        // FlxVideo uses pauseVideo() method for HTML5
        if (lyricsLol != null) lyricsLol.pauseVideo();
        if (lyricsGood != null) lyricsGood.pauseVideo();
        FlxTween.globalManager.forEach(function(twn:FlxTween) if(!twn.finished) twn.active = false);
    }

    override public function onResume(event) {
        super.onResume(event);
        // FlxVideo uses resumeVideo() method for HTML5
        if (lyricsLol != null) lyricsLol.resumeVideo();
        if (lyricsGood != null) lyricsGood.resumeVideo();
        FlxTween.globalManager.forEach(function(twn:FlxTween) if(!twn.finished) twn.active = true);
    }

    override public function onSongRetry(event) {
        super.onSongRetry(event);
        if (lyricsTextChidas != null) {
            lyricsTextChidas.visible = false;
            lyricsTextChidas.text = "";
        }
        if (lyricsLol != null) { lyricsLol.destroy(); lyricsLol = null; }
        if (lyricsGood != null) { lyricsGood.destroy(); lyricsGood = null; }
        FlxG.resetState();
    }

    function tweenPlayerAlpha(target:Float, duration:Float) {
        if (playerAlphaTween != null) playerAlphaTween.cancel();
        playerAlphaTween = FlxTween.num(playerAlpha, target, duration, {
            ease: FlxEase.cubeInOut,
            onUpdate: function(twn:FlxTween) {
                playerAlpha = twn.value;
                if (game.playerStrumline != null) {
                    game.playerStrumline.alpha = playerAlpha;
                    game.playerStrumline.notes.forEach(function(n) n.alpha = playerAlpha);
                }
            }
        });
    }

    function changeStrumsAlpha(newAlpha:Float) {
        playerAlpha = newAlpha;
        if (game.playerStrumline != null) {
            game.playerStrumline.alpha = playerAlpha;
            game.playerStrumline.notes.forEach(function(n) n.alpha = playerAlpha);
        }
        if (game.opponentStrumline != null) {
            game.opponentStrumline.alpha = newAlpha;
            game.opponentStrumline.notes.forEach(function(n) n.alpha = newAlpha);
        }
    }

    override function onNoteCreation(event) {
        super.onNoteCreation(event);
        if (event.note.strumLine == game.playerStrumline) {
            event.note.alpha = playerAlpha;
        } else {
            event.note.alpha = game.opponentStrumline.alpha;
        }
    }

    override function onSongEnd(event) {
        super.onSongEnd(event);
        // Let the game handle the song end normally (goes to results/freeplay)
    }
}
