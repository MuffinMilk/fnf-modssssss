    function new() {
        super('youtubeland');
    }

    function triggerEvent(notUsed:String, character:String, characterName:String) {
        var charData = CharacterDataParser.parseCharacterData(characterName.toLowerCase());
        CharacterDataParser.characterCache.h[CharacterDataParser.characterCache.h.length + 1] = charData;

        switch(character) {
            case 'bf':
                var zIndex = PlayState.instance.currentStage.getBoyfriend().zIndex;
                PlayState.instance.currentStage.getBoyfriend().destroy();
                var boyfriend = CharacterDataParser.fetchCharacter(characterName.toLowerCase());
                if (boyfriend != null) {
                    boyfriend.set_characterType(CharacterType.BF);
                    boyfriend.initHealthIcon(false);
                    PlayState.instance.currentStage.addCharacter(boyfriend, CharacterType.BF);
                    PlayState.instance.currentStage.getBoyfriend().zIndex = zIndex;
                }
            case 'gf':
                var zIndex = PlayState.instance.currentStage.getGirlfriend().zIndex;
                PlayState.instance.currentStage.getGirlfriend().destroy();
                var girlfriend = CharacterDataParser.fetchCharacter(characterName.toLowerCase());
                if (girlfriend != null) {
                    girlfriend.set_characterType(CharacterType.GF);
                    girlfriend.initHealthIcon(false);
                    PlayState.instance.currentStage.addCharacter(girlfriend, CharacterType.GF);
                    PlayState.instance.currentStage.getGirlfriend().zIndex = zIndex;
                }
            case 'dad':
                var zIndex = PlayState.instance.currentStage.getDad().zIndex;
                PlayState.instance.currentStage.getDad().destroy();
                var dad = CharacterDataParser.fetchCharacter(characterName.toLowerCase());
                if (dad != null) {
                    dad.set_characterType(CharacterType.DAD);
                    dad.initHealthIcon(true);
                    PlayState.instance.currentStage.addCharacter(dad, CharacterType.DAD);
                    PlayState.instance.currentStage.getDad().zIndex = zIndex;
                }
        }
        PlayState.instance.currentStage.refresh();
    }

    override function onCreate(event) {
        super.onCreate(event);
        _clipRect = new FlxRect(0, 0, 0, BATTERY_HEIGHT);
        game = PlayState.instance;

        // Initialize shaders safely
        try {
            sharpen = new FlxRuntimeShader(Assets.getText(Paths.frag("sharpen")));
            saturation = new FlxRuntimeShader(Assets.getText(Paths.frag("saturation")));
            PlayState.instance.camGame.filters = [new ShaderFilter(sharpen), new ShaderFilter(saturation)];
        } catch (e:Dynamic) {
            trace("Shader loading failed, continuing without shaders: " + e);
        }

        // char1 = new FlxSprite();
        // char1.frames = Paths.getSparrowAtlas("characters/OLB/NugRUN");
        // char1.cameras = [game.camCutscene];
        // add(char1);
        // char2 = new FlxSprite();
        // char2.frames = Paths.getSparrowAtlas("characters/OLB/Nugget");
        // char2.cameras = [game.camCutscene];
        // add(char2);
        // char3 = new FlxSprite();
        // char3.frames = Paths.getSparrowAtlas("characters/OLB/Max");
        // char3.cameras = [game.camCutscene];
        // add(char3);
        // char4 = new FlxSprite();
        // char4.frames = Paths.getSparrowAtlas("characters/OLB/MaxRUN");
        // char4.cameras = [game.camCutscene];
        // add(char4);

        // new FlxTimer().start(0.1, function(_) {
        //     // remove(char1);
        // });


        setupHUD();
        setupCineBars();
        setupStageElements();
        // Videos are loaded on-demand for HTML5 compatibility
        realStage(false);
        MDP = true;

        // PlayState.instance.add(lyricsGood);
        // PlayState.instance.add(lyricsLol);
    }

    override function onSongStart(event) {
        super.onSongStart(event);
        game.playerStrumline.cameras = [game.camVideo];
        // game.playerStrumline.zIndex = 9999;

        if (!FlxG.onMobile) {
            game.playerStrumline.x = FlxG.width - 448;
        }
    }

    function setupHUD() {
        game = PlayState.instance;
        if (game.healthBar != null) game.healthBar.visible = false;
        if (game.healthBarBG != null) game.healthBarBG.visible = false;
        if (game.scoreText != null) game.scoreText.visible = false;
        if (game.songProgress != null) game.songProgress.visible = false;
        if (game.opponentStrumline != null) game.opponentStrumline.visible = false;

        var batteryX = (FlxG.width / 2) - (BATTERY_WIDTH / 2);
        var isDown = FlxG.onMobile || Preferences.downscroll;
        var batteryY = isDown ? 25 : 600;

        batteryBG = new FlxSprite(batteryX, batteryY).makeGraphic(BATTERY_WIDTH, BATTERY_HEIGHT, 0xAA000000);
        batteryBG.cameras = [PlayState.instance.camHUD];
        batteryBG.zIndex = 300;
        PlayState.instance.add(batteryBG);

        batteryGradient = new FlxSprite(batteryX, batteryY).loadGraphic(Paths.image('ui/batteryGradient'));
        batteryGradient.antialiasing = true;
        batteryGradient.cameras = [PlayState.instance.camHUD];
        batteryGradient.zIndex = 301;
        PlayState.instance.add(batteryGradient);

        batteryBorder = new FlxSprite(batteryX - 5, batteryY - 10).loadGraphic(Paths.image('ui/batteryHealth'));
        batteryBorder.scale.set(0.7, 0.7);
        batteryBorder.antialiasing = true;
        batteryBorder.updateHitbox();
        batteryBorder.cameras = [PlayState.instance.camHUD];
        batteryBorder.zIndex = 302;
        PlayState.instance.add(batteryBorder);

        var gradTopY = isDown ? 590 : 0;
        var gradBotY = isDown ? 40 : 650;

        shortGradientTop = new FlxSprite(batteryX - 50, gradTopY).loadGraphic(Paths.image('ui/shortGradient'));
        shortGradientTop.scale.set(2.1, 2.1);
        shortGradientTop.flipY = isDown;
        shortGradientTop.cameras = [PlayState.instance.camCutscene];
        shortGradientTop.zIndex = 400;
        PlayState.instance.add(shortGradientTop);

        shortGradientBottom = new FlxSprite(batteryX - 50, gradBotY).loadGraphic(Paths.image('ui/shortGradient'));
        shortGradientBottom.scale.set(2.1, 2.1);
        shortGradientBottom.flipY = !isDown;
        shortGradientBottom.cameras = [PlayState.instance.camCutscene];
        shortGradientBottom.zIndex = 401;
        PlayState.instance.add(shortGradientBottom);

        watermark = new FlxText(0, (isDown ? 180 : 550), 0, "@MaxDesignPro", 32);
        watermark.setFormat(Paths.font('watermark.ttf'), 32, 0x0e0500);
        watermark.scale.set(0.5, 0.5);
        watermark.alpha = 0.32;
        watermark.screenCenter(0x01);
        watermark.cameras = [PlayState.instance.camCutscene];
        watermark.zIndex = 405;
        PlayState.instance.add(watermark);

        healthIcon = new FlxSprite(30, FlxG.height - 260);
        healthIcon.frames = Paths.getSparrowAtlas('icons/NugIcon');
        healthIcon.animation.addByPrefix('full', 'NUGGET0000', 24, false);
        healthIcon.animation.addByPrefix('good', 'NUGGET0001', 24, false);
        healthIcon.animation.addByPrefix('warning', 'NUGGET0002', 24, false);
        healthIcon.animation.addByPrefix('danger', 'NUGGET0003', 24, false);
        healthIcon.cameras = [PlayState.instance.camHUD];
        healthIcon.zIndex = 310;
        healthIcon.scale.set(0.8, 0.8);
        PlayState.instance.add(healthIcon);

        scoreText = new FlxText(healthIcon.x + 190, healthIcon.y + 120, 0, "Score: 0", 30);
        scoreText.setFormat(Paths.font("MDP.ttf"), 30, 0xFFF7F1DF, 'left', FlxTextBorderStyle.OUTLINE, FlxColor.BLACK);
        scoreText.borderSize = 2;
        scoreText.cameras = [PlayState.instance.camHUD];
        scoreText.zIndex = 311;
        PlayState.instance.add(scoreText);

        missText = new FlxText(scoreText.x, scoreText.y + 40, 0, "Misses: 0", 30);
        missText.setFormat(Paths.font("MDP.ttf"), 30, 0xFFF7F1DF, 'left', FlxTextBorderStyle.OUTLINE, FlxColor.BLACK);
        missText.borderSize = 2;
        missText.cameras = [PlayState.instance.camHUD];
        missText.zIndex = 312;
        PlayState.instance.add(missText);
    }

    function setupCineBars() {
        var barWidth = Math.ceil((FlxG.width - (9 / 16 * FlxG.height)) / 2);
        leftBar = new FlxSprite(0, 0).makeGraphic(barWidth, FlxG.height, 0xFF0f0f0f);
        rightBar = new FlxSprite(FlxG.width - barWidth, 0).makeGraphic(barWidth, FlxG.height, 0xFF0f0f0f);
        leftBar.cameras = rightBar.cameras = [PlayState.instance.camCutscene];
        leftBar.zIndex = 600;
        rightBar.zIndex = 601;
        PlayState.instance.add(leftBar);
        PlayState.instance.add(rightBar);
    }

